# TSI Studio .gitignore

# Environment files
.env
.env.local
.env.*.local
.envrc
backend/.env
frontend/.env

# Frontend dependencies and builds
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/

# Python virtual environments
venv/
backend/venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class

# Backend generated session storage
backend/storage/sessions/

# Logs
*.log
backend/*.log
frontend/*.log

# Testing / cache
.pytest_cache/
.coverage
htmlcov/
.cache/

# Local tools
.playwright-mcp/

# Editor files
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Temporary files
tempCodeRunnerFile.py